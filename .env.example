# =============================================================================
# TrendMart — Environment Variables Template
# Author: George Papasotiriou
# Date Created: March 28, 2026
#
# HOW TO USE:
#   1. Copy this file to .env in the project root:
#         cp .env.example .env        (Linux/Mac)
#         copy .env.example .env      (Windows)
#   2. Replace any placeholder values with your real credentials.
#   3. The project runs with built-in development defaults even WITHOUT .env,
#      but the AI assistant will not work until you set OPENROUTER_API_KEY.
#
# NOTE: .env is gitignored — it will never be committed to GitHub.
#       This .env.example file is safe to commit (no real secrets).
# =============================================================================

# ── Django Core ───────────────────────────────────────────────────────────────
# A dev fallback is built into settings.py, so SECRET_KEY is optional in dev.
# For production: generate a real one and set it here.
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=True

# Set to your domain(s) in production, e.g.: trendmart.com,www.trendmart.com
ALLOWED_HOSTS=*

# ── AI Assistant — OpenRouter API ─────────────────────────────────────────────
# Required for the AI chat assistant to work.
# Get your free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Optional: Stripe Payments ─────────────────────────────────────────────────
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Optional: Google OAuth2 (Social Login) ────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Optional: Email (SMTP) ────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@trendmart.com

# ── Optional: PostgreSQL Database ─────────────────────────────────────────────
# Leave commented out to use the default SQLite database in development.
# DATABASE_URL=postgresql://user:password@localhost:5432/trendmart

# ── Optional: Redis (caching & WebSockets) ────────────────────────────────────
# Leave commented out to use the default in-memory cache in development.
# REDIS_URL=redis://127.0.0.1:6379/0
