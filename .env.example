# =============================================================================
# TrendMart — Environment Variables TEMPLATE
# Author: George Papasotiriou
# Date Created: March 28, 2026
#
# HOW TO USE:
#   1. Copy this file:  copy .env.example .env    (Windows)
#                       cp  .env.example .env     (Mac/Linux)
#   2. Fill in all required values marked with <angle brackets>
#   3. Never commit your .env file — it is already listed in .gitignore
#
# Variables marked REQUIRED must be set before the server will start.
# Variables marked OPTIONAL have safe defaults and can be left blank.
# =============================================================================

# ── Django Core (REQUIRED) ────────────────────────────────────────────────────
# Generate a secure key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=<generate-a-new-secret-key>

# Set to False in production — exposes full stack traces when True
DEBUG=True

# Comma-separated list of hostnames that Django will serve.
# Use * only for local development. In production: yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=127.0.0.1,localhost

# ── AI Assistant — OpenRouter API (REQUIRED for AI chat) ─────────────────────
# Create a free account and get your key at: https://openrouter.ai/keys
# Without this key, the AI assistant falls back to built-in keyword responses.
OPENROUTER_API_KEY=<your-openrouter-api-key>

# Free models to try: nvidia/nemotron-3-super-120b-a12b:free, google/gemini-flash-1.5:free
# Paid models (more capable): openai/gpt-4o-mini, anthropic/claude-3-haiku
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# ── Production Database (OPTIONAL — defaults to SQLite) ───────────────────────
# SQLite works for development. For production, use PostgreSQL.
# Format: postgresql://username:password@hostname:5432/database_name
# Hosting providers (Railway, Render, Heroku) inject this automatically.
# DATABASE_URL=postgresql://user:password@localhost:5432/trendmart

# ── Redis Cache & Sessions (OPTIONAL) ────────────────────────────────────────
# When set, enables: cross-process rate limiting, shared session storage,
# and Django Channels WebSocket support. Dramatically improves performance.
# Format: redis://[:password@]hostname[:port][/db-number]
# REDIS_URL=redis://127.0.0.1:6379/0

# ── Error Monitoring — Sentry (OPTIONAL) ──────────────────────────────────────
# Sign up free at https://sentry.io — get your DSN from Project → Settings → DSN
# When set, all unhandled exceptions are sent to your Sentry dashboard.
# SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ── Site Domain (OPTIONAL — defaults to localhost:8000) ──────────────────────
# Used by the sitemap generator and any absolute URL generation.
# Set to your actual domain in production: trendmart.com
# SITE_DOMAIN=trendmart.com

# ── App Version (OPTIONAL — used by Sentry for release tracking) ──────────────
# APP_VERSION=trendmart@1.0.0

# ── Optional: Stripe Payments ─────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Optional: Google OAuth2 (social login) ────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Optional: Email (SMTP) ────────────────────────────────────────────────────
# In development, emails print to the console (EMAIL_BACKEND = console).
# In production (DEBUG=False), these settings are required for order emails.
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=<your-sendgrid-or-smtp-api-key>
DEFAULT_FROM_EMAIL=TrendMart <noreply@trendmart.com>

# ── Sentry Sampling (OPTIONAL) ────────────────────────────────────────────────
# What fraction of transactions to trace (0.0 to 1.0). 0.1 = 10% (recommended).
# SENTRY_TRACES_RATE=0.1
