# =============================================================================
# TrendMart — Environment Variables TEMPLATE
# Author: George Papasotiriou
# Date Created: March 28, 2026
#
# HOW TO USE:
#   1. Copy this file:  copy .env.example .env    (Windows)
#                       cp  .env.example .env     (Mac/Linux)
#   2. Fill in all required values marked with <angle brackets>
#   3. Never commit your .env file — it is already listed in .gitignore
# =============================================================================

# ── Django Core (REQUIRED) ────────────────────────────────────────────────────
# Generate a secure key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=<generate-a-new-secret-key>

# Set to False in production
DEBUG=True

# Comma-separated. Use * only for local development.
ALLOWED_HOSTS=127.0.0.1,localhost

# ── AI Assistant — OpenRouter API (REQUIRED for AI chat) ─────────────────────
# Create a free account and get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=<your-openrouter-api-key>
# Recommended fast + cheap model. Alternatives: anthropic/claude-3-haiku, google/gemini-flash-1.5
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Optional: Stripe Payments ─────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Optional: Google OAuth2 ───────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Optional: Email (SMTP) ────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@trendmart.com

# ── Optional: PostgreSQL Database ─────────────────────────────────────────────
# Leave commented to use SQLite (fine for development)
# DATABASE_URL=postgresql://user:password@localhost:5432/trendmart

# ── Optional: Redis (for caching & WebSocket real-time updates) ───────────────
# REDIS_URL=redis://127.0.0.1:6379/0
