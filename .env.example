# =============================================================================
# TrendMart — Environment Variables Template
# Author: George Papasotiriou
# Date Created: March 28, 2026
#
# Copy this file to .env and fill in your real values.
# .env is gitignored — this file is safe to commit.
# =============================================================================

# ── Django Core ───────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=*

# ── AI Assistant — OpenRouter API ─────────────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Optional: Stripe Payments ─────────────────────────────────────────────────
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Optional: Google OAuth2 ───────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Optional: Email (SMTP) ────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@trendmart.com

# ── Optional: PostgreSQL Database ─────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/trendmart

# ── Optional: Redis ───────────────────────────────────────────────────────────
# REDIS_URL=redis://127.0.0.1:6379/0
