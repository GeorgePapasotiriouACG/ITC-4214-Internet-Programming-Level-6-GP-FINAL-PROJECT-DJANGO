# =============================================================================
# TrendMart — Git Ignore Rules
# Author: George Papasotiriou
# Date Created: March 28, 2026
#
# Files and directories that should NEVER be committed to version control.
# =============================================================================

# ── Environment & Secrets (CRITICAL — never commit these) ─────────────────────
.env
*.env
.env.local
.env.production
.env.staging

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
.Python

# ── Virtual Environments ──────────────────────────────────────────────────────
venv/
env/
.venv/
ENV/
virtualenv/

# ── Django ────────────────────────────────────────────────────────────────────
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
static_root/

# ── Build / Distribution ──────────────────────────────────────────────────────
dist/
build/
*.egg-info/
.eggs/
*.egg

# ── IDE & Editor files ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Testing & Coverage ────────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.tox/
*.coveragerc

# ── Node (if any frontend tooling is added) ───────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Misc ──────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.orig
