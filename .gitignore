# =============================================================================
# TrendMart — .gitignore
# Author: George Papasotiriou
# Date Created: March 28, 2026
# =============================================================================

# ── SECRETS — never commit these ──────────────────────────────────────────────
.env
*.env
!.env.example

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
env/
ENV/
.venv/
.env.bak

# ── Django ────────────────────────────────────────────────────────────────────
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
static_collected/

# ── Node (if any frontend tooling is added) ───────────────────────────────────
node_modules/
npm-debug.log*

# ── OS artifacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── Coverage & testing ────────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.tox/

# ── Cache ─────────────────────────────────────────────────────────────────────
.cache/
*.cache
